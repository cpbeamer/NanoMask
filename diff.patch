+fn evaluateAnthropicLongSession(allocator: std.mem.Allocator, definition: FlowDefinition, report: *FlowResult) !void {
+    const request_headers = [_]http.Header{
+        .{ .name = "x-api-key", .value = "anthropic-long-session-key" },
