{
  "annotations": {
    "list": []
  },
  "description": "NanoMask Privacy Proxy - Operational Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Request Throughput",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(nanomask_requests_total[1m])",
          "legendFormat": "Requests/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Active Connections",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "nanomask_active_connections",
          "legendFormat": "Connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 500, "color": "yellow" },
              { "value": 900, "color": "red" }
            ]
          },
          "max": 1000
        }
      }
    },
    {
      "title": "Redaction Status",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "nanomask_redaction_stage_total{stage=\"entity_redacted\"}",
          "legendFormat": "Entity Redactions"
        },
        {
          "expr": "nanomask_redaction_stage_total{stage=\"pattern_redacted\"}",
          "legendFormat": "Pattern Redactions"
        }
      ]
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(nanomask_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(nanomask_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(nanomask_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Response Codes",
      "type": "piechart",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (code) (nanomask_response_code_total)",
          "legendFormat": "{{code}}"
        }
      ]
    },
    {
      "title": "Bytes Processed",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "rate(nanomask_bytes_processed_total{direction=\"request\"}[1m])",
          "legendFormat": "Request bytes/s"
        },
        {
          "expr": "rate(nanomask_bytes_processed_total{direction=\"response\"}[1m])",
          "legendFormat": "Response bytes/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "title": "Dropped Log Lines",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "nanomask_dropped_log_lines",
          "legendFormat": "Dropped"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["nanomask", "privacy", "proxy"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NanoMask Privacy Proxy",
  "uid": "nanomask-ops",
  "version": 1,
  "weekStart": ""
}
