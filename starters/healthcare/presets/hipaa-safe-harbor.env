# NanoMask Environment Configuration: HIPAA Safe Harbor Preset
# This is a starter configuration that uses the hipaa-safe-harbor profile
# to automatically enable all required redaction identifiers.

NANOMASK_LISTEN_HOST=0.0.0.0
NANOMASK_LISTEN_PORT=8081

# Replace with the actual URL of your FHIR API or internal service
NANOMASK_TARGET_HOST=internal-fhir-api.local
NANOMASK_TARGET_PORT=443
NANOMASK_TARGET_TLS=true

# Enable the HIPAA Safe Harbor preset profile
# This turns on detection for Names, Email, Phone, Dates, Addresses,
# Accounts, Licenses, Healthcare IDs (MRN/ICD), IPs, URLs, Vehicle IDs,
# and activates the Stage 4 context rules.
NANOMASK_PROFILE=hipaa-safe-harbor

# Override the default SCAN action to KEEP missing JSON fields
# (allows non-matching JSON fields to passthrough normally)
NANOMASK_SCHEMA_DEFAULT=KEEP

# The path to your entity roster (Patient/Provider names)
NANOMASK_ENTITY_FILE=/etc/nanomask/entities.txt

# The path to your traffic schema definition
NANOMASK_SCHEMA_FILE=/etc/nanomask/schema.nmschema

# The path to your 64-character hex HMAC pseudonymization key
NANOMASK_HASH_KEY_FILE=/etc/nanomask/hash-key.txt
