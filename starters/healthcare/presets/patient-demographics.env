# Local sidecar-style preset for intake and registration payloads.
# Replace the target host, port, and hash key before production use.
NANOMASK_LISTEN_HOST=127.0.0.1
NANOMASK_LISTEN_PORT=8081
NANOMASK_TARGET_HOST=httpbin.org
NANOMASK_TARGET_PORT=80
NANOMASK_ENTITY_FILE=starters/healthcare/entities/patient-demographics.txt
NANOMASK_SCHEMA_FILE=starters/healthcare/schemas/patient-demographics.nmschema
NANOMASK_SCHEMA_DEFAULT=KEEP
NANOMASK_HASH_KEY_FILE=starters/healthcare/hash-key.example.txt
NANOMASK_ENABLE_EMAIL=true
NANOMASK_ENABLE_PHONE=true
NANOMASK_ENABLE_HEALTHCARE=true
NANOMASK_AUDIT_LOG=true
NANOMASK_UNSUPPORTED_REQUEST_BODY_BEHAVIOR=reject
NANOMASK_UNSUPPORTED_RESPONSE_BODY_BEHAVIOR=bypass
